{
	"name": "franklin-workspace",
	"private": true,
	"license": "Apache-2.0",
	"workspaces": [
		"packages/*",
		"packages/ui/*",
		"apps/*",
		"apps/shared/*"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "node ./scripts/in-parallel.mjs --mb 800 --name root-build -- tsc -b",
		"clean": "tsc -b --clean",
		"lint": "node ./scripts/in-parallel.mjs --mb 3250 --name root-lint -- eslint . --cache --max-warnings=0",
		"lint:fix": "npm run lint -- --fix",
		"typecheck": "npm run typecheck --workspaces --if-present",
		"test": "node ./scripts/in-parallel.mjs --mb 1750 --name root-test -- vitest run",
		"test:watch": "vitest",
		"test:changed": "vitest run --changed",
		"check": "npm run format:check && npm run lint && npm run build",
		"release:obsidian": "node ./scripts/obsidian-release/cli.mjs",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"postinstall": "patch-package",
		"prepare": "husky"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.4.0",
		"@types/shell-quote": "^1.7.5",
		"@vitest/eslint-plugin": "^1.6.10",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.2.19",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"patch-package": "^8.0.1",
		"prettier": "^3.8.1",
		"proper-lockfile": "^4.1.2",
		"tsx": "^4.21.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.58.0",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@anthropic-ai/sandbox-runtime": "^0.0.46",
		"@codemirror/commands": "github:codemirror/commands",
		"@codemirror/state": "6.6.0",
		"diff": "^9.0.0",
		"jsdom": "^29.0.2"
	},
	"overrides": {
		"@codemirror/state": "6.6.0",
		"basic-ftp": "5.3.0",
		"dompurify": "3.4.0",
		"langium": "4.2.2",
		"lodash-es": "4.18.1",
		"protobufjs": "7.5.5",
		"vite": "6.4.2"
	}
}

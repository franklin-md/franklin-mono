{
	"name": "franklin-workspace",
	"private": true,
	"packageManager": "npm@11.6.2",
	"workspaces": [
		"packages/*",
		"packages/lib/*",
		"packages/ui/*",
		"apps/*"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "tsc -b",
		"clean": "tsc -b --clean",
		"lint": "eslint . --cache --max-warnings=0",
		"lint:fix": "npm run lint -- --fix",
		"typecheck": "npm run typecheck --workspaces --if-present",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:changed": "vitest run --changed",
		"check": "npm run format:check && npm run lint && npm run build",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.4.0",
		"@vitest/eslint-plugin": "^1.6.10",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.2.19",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"prettier": "^3.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.57.0",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@anthropic-ai/sandbox-runtime": "^0.0.46",
		"jsdom": "^29.0.2"
	}
}

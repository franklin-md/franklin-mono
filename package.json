{
	"name": "franklin-workspace",
	"private": true,
	"license": "Apache-2.0",
	"workspaces": [
		"packages/*",
		"packages/ui/*",
		"apps/*",
		"apps/shared/*"
	],
	"engines": {
		"node": ">=22",
		"npm": ">=11.10.0"
	},
	"scripts": {
		"build": "tsc -b",
		"clean": "tsc -b --clean",
		"lint": "eslint . --cache --max-warnings=0",
		"lint:fix": "npm run lint -- --fix",
		"typecheck": "npm run typecheck --workspaces --if-present",
		"test": "vitest run",
		"test:browser": "npm run test:browser --workspaces --if-present",
		"test:watch": "vitest",
		"test:changed": "vitest run --changed",
		"check": "npm run format:check && npm run lint && npm run build",
		"release:obsidian": "node ./scripts/obsidian-release/cli.mjs",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"postinstall": "patch-package",
		"prepare": "husky"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@types/node": "25.5.0",
		"@types/shell-quote": "1.7.5",
		"@vitest/eslint-plugin": "1.6.14",
		"eslint": "10.1.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-obsidianmd": "0.2.9",
		"eslint-plugin-storybook": "10.3.3",
		"globals": "17.4.0",
		"husky": "9.1.7",
		"patch-package": "8.0.1",
		"prettier": "3.8.1",
		"tsx": "4.21.0",
		"typescript": "5.9.3",
		"typescript-eslint": "8.58.0",
		"vitest": "4.1.7"
	},
	"dependencies": {
		"@anthropic-ai/sandbox-runtime": "0.0.46",
		"@codemirror/commands": "6.10.3",
		"@codemirror/state": "6.6.0",
		"diff": "9.0.0",
		"jsdom": "29.0.2"
	},
	"overrides": {
		"@codemirror/state": "6.6.0",
		"basic-ftp": "5.3.0",
		"dompurify": "3.4.0",
		"langium": "4.2.2",
		"lodash-es": "4.18.1",
		"protobufjs": "7.6.1",
		"vite": "6.4.2"
	},
	"packageManager": "npm@11.12.1",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=22",
			"onFail": "error"
		},
		"packageManager": {
			"name": "npm",
			"version": ">=11.10.0",
			"onFail": "error"
		}
	}
}

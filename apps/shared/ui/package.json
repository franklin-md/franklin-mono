{
	"name": "@franklin/ui",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./styles/*": "./src/styles/*"
	},
	"scripts": {
		"build": "node ../../../scripts/in-parallel.mjs --mb 1000 --name ui-build -- tsc -b tsconfig.build.json",
		"typecheck": "node ../../../scripts/in-parallel.mjs --mb 950 --name ui-typecheck -- tsc -b tsconfig.build.json --pretty false",
		"test": "node ../../../scripts/in-parallel.mjs --mb 1700 --name ui-test -- vitest run --passWithNoTests",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"dependencies": {
		"@fontsource-variable/geist-mono": "^5.2.7",
		"@fontsource-variable/inter": "^5.2.8",
		"@franklin/extensions": "*",
		"@franklin/lib": "*",
		"@franklin/mini-acp": "*",
		"@franklin/react": "*",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-scroll-area": "^1.2.3",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.2.0",
		"@radix-ui/react-tabs": "^1.1.12",
		"@streamdown/code": "^1.1.1",
		"@streamdown/math": "^1.0.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"katex": "^0.16.44",
		"lucide-react": "^0.511.0",
		"react-icons": "^5.6.0",
		"react-textarea-autosize": "^8.5.9",
		"shiki": "^3.4.2",
		"streamdown": "^2.5.0",
		"tailwind-merge": "^3.3.0"
	},
	"peerDependencies": {
		"react": "^18.3.1 || ^19.0.0",
		"react-dom": "^18.3.1 || ^19.0.0"
	},
	"devDependencies": {
		"@storybook/addon-docs": "^10.2.19",
		"@storybook/react-vite": "^10.2.19",
		"@tailwindcss/vite": "^4.1.4",
		"@testing-library/react": "^15.0.7",
		"@types/react": "^18.3.0",
		"@types/react-dom": "^18.3.0",
		"jsdom": "^28.1.0",
		"storybook": "^10.2.19",
		"tailwindcss": "^4.1.4"
	}
}

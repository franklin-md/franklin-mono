{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"rootDir": "./src",
		"outDir": "./dist",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"composite": true,
		"declaration": true,
		"declarationMap": true,
		"jsx": "react-jsx"
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"references": [
		{ "path": "../../packages/lib" },
		{ "path": "../../packages/extensions" },
		{ "path": "../../packages/agent" },
		{ "path": "../../packages/node" },
		{ "path": "../../packages/ui/react" },
		{ "path": "../shared/ui" }
	]
}

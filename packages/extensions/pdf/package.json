{
	"name": "@franklin/extension-pdf",
	"private": true,
	"license": "Apache-2.0",
	"version": "0.0.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "tsc -b tsconfig.json",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"test": "vitest run --passWithNoTests"
	},
	"dependencies": {
		"@franklin/agent": "0.0.0",
		"@franklin/extensibility": "0.0.0",
		"@franklin/lib": "0.0.0",
		"@franklin/mini-acp": "0.0.0",
		"@mistralai/mistralai": "2.2.1",
		"unpdf": "1.6.2",
		"zod": "4.3.6"
	}
}

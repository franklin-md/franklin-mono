{
	"name": "@franklin/node",
	"private": true,
	"license": "Apache-2.0",
	"version": "0.0.0",
	"type": "module",
	"main": "./dist/index.",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "node ../../scripts/in-parallel.mjs --mb 800 --name node-build -- tsc -b tsconfig.json",
		"typecheck": "node ../../scripts/in-parallel.mjs --mb 550 --name node-typecheck -- tsc --noEmit -p tsconfig.json",
		"test": "node ../../scripts/in-parallel.mjs --mb 1050 --name node-test -- vitest run --passWithNoTests"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "^0.16.1",
		"@franklin/agent": "*",
		"@franklin/lib": "*",
		"@franklin/mini-acp": "*",
		"@mariozechner/pi-agent-core": "^0.61.0",
		"@mariozechner/pi-ai": "^0.61.0",
		"node-fetch": "^3.3.2",
		"shell-quote": "^1.8.3"
	},
	"devDependencies": {
		"@types/shell-quote": "^1.7.5"
	}
}

{
	"name": "@franklin/electron",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"exports": {
		"./main": {
			"types": "./dist/main/index.d.ts",
			"import": "./dist/main/index.js"
		},
		"./preload": {
			"types": "./dist/preload/index.d.ts",
			"import": "./dist/preload/index.js"
		},
		"./renderer": {
			"types": "./dist/renderer/index.d.ts",
			"import": "./dist/renderer/index.js"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "node ../../scripts/in-parallel.mjs --mb 800 --name electron-build -- tsc -b tsconfig.json",
		"typecheck": "node ../../scripts/in-parallel.mjs --mb 600 --name electron-typecheck-main -- tsc --noEmit -p tsconfig.main.json --pretty false && node ../../scripts/in-parallel.mjs --mb 600 --name electron-typecheck-preload -- tsc --noEmit -p tsconfig.preload.json --pretty false && node ../../scripts/in-parallel.mjs --mb 800 --name electron-typecheck-renderer -- tsc --noEmit -p tsconfig.renderer.json --pretty false",
		"test": "node ../../scripts/in-parallel.mjs --mb 600 --name electron-test -- vitest run --passWithNoTests"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "^0.16.1",
		"@franklin/agent": "*",
		"@mariozechner/pi-ai": "^0.61.0",
		"@franklin/lib": "*",
		"@franklin/mini-acp": "*"
	},
	"devDependencies": {
		"electron": "^39.8.5"
	},
	"peerDependencies": {
		"electron": ">=30"
	},
	"peerDependenciesMeta": {
		"electron": {
			"optional": true
		}
	}
}

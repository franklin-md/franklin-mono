{
	"name": "@franklin/lib",
	"private": true,
	"license": "Apache-2.0",
	"version": "0.0.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./proxy": {
			"types": "./dist/proxy/index.d.ts",
			"import": "./dist/proxy/index.js"
		},
		"./transport": {
			"types": "./dist/transport/index.d.ts",
			"import": "./dist/transport/index.js"
		},
		"./transport/node": {
			"types": "./dist/transport/node.d.ts",
			"import": "./dist/transport/node.js"
		},
		"./middleware": {
			"types": "./dist/middleware/index.d.ts",
			"import": "./dist/middleware/index.js"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "node ../../scripts/in-parallel.mjs --mb 800 --name lib-build -- tsc -b tsconfig.json",
		"typecheck": "node ../../scripts/in-parallel.mjs --mb 450 --name lib-typecheck -- tsc --noEmit -p tsconfig.json",
		"test": "node ../../scripts/in-parallel.mjs --mb 1050 --name lib-test -- vitest run --passWithNoTests"
	},
	"dependencies": {
		"ignore": "^7.0.5",
		"pathe": "^2.0.3",
		"zod": "^4.0.0"
	}
}

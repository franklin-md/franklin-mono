{
	"name": "@franklin/mini-acp",
	"private": true,
	"license": "Apache-2.0",
	"version": "0.0.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "node ../../scripts/in-parallel.mjs --mb 800 --name mini-acp-build -- tsc -b tsconfig.json",
		"typecheck": "node ../../scripts/in-parallel.mjs --mb 600 --name mini-acp-typecheck -- tsc --noEmit -p tsconfig.json",
		"test": "node ../../scripts/in-parallel.mjs --mb 950 --name mini-acp-test -- vitest run --passWithNoTests"
	},
	"dependencies": {
		"@franklin/lib": "*",
		"@mariozechner/pi-ai": "^0.61.0",
		"@mariozechner/pi-agent-core": "^0.61.0",
		"dotenv": "^17.3.1",
		"pi-agents": "^0.1.0"
	}
}

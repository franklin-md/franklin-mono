{
	"name": "@franklin/react",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "node ../../../scripts/in-parallel.mjs --mb 800 --name react-build -- tsc -b tsconfig.json",
		"typecheck": "node ../../../scripts/in-parallel.mjs --mb 550 --name react-typecheck -- tsc --noEmit -p tsconfig.json",
		"test": "node ../../../scripts/in-parallel.mjs --mb 2250 --name react-test -- vitest run --passWithNoTests"
	},
	"dependencies": {
		"@franklin/agent": "*",
		"@franklin/extensions": "*",
		"@radix-ui/react-slot": "^1.1.1",
		"dequal": "^2.0.3"
	},
	"peerDependencies": {
		"react": "^18.3.1 || ^19.0.0"
	},
	"devDependencies": {
		"@testing-library/react": "^15.0.7",
		"jsdom": "^28.1.0"
	}
}
